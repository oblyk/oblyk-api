#!/usr/bin/env ruby
# frozen_string_literal: true

# Standalone test script for DiscChartService.
# Reads route data from a tab-separated CSV file (Oblyk export format) and
# generates a PDF with one circular disc per anchor, sorted by anchor number.
#
# CSV columns used (Oblyk export format):
#   hold_colors  Hex color(s), comma-separated (e.g. "#ff0000" or "#ff0000, #0000ff")
#   grade        Grade label (e.g. "6b+")
#   openers      Setter name(s), comma-separated
#   anchor       Anchor/relay number (integer)
#   short_url    Short URL used to generate the QR code
#
# Usage:
#   cd oblyk-api
#   bundle exec ruby bin/test_charts <csv_file>
#
# Example:
#   bundle exec ruby bin/test_charts app/services/adrenaline_garches.csv

require_relative '../config/environment'
require_relative '../app/services/disc_chart_service'
require 'rqrcode'
require 'csv'

if ARGV.empty?
  warn "Usage: bundle exec ruby #{__FILE__} <csv_file>"
  warn "  Accepts tab-separated CSV files in Oblyk export format."
  exit 1
end

csv_path = File.expand_path(ARGV[0])
unless File.exist?(csv_path)
  warn "File not found: #{csv_path}"
  exit 1
end

rows = CSV.read(csv_path, col_sep: "\t", headers: true)

routes = rows.map do |row|
  colors = row['hold_colors'].split(/,\s*/)
  openers = row['openers'].split(/,\s*/).map { |name| { name: name.strip } }
  short_url = row['short_url']
  qr_svg = RQRCode::QRCode.new(short_url, level: :l).as_svg(viewbox: true, use_path: true)

  {
    anchor_number: row['anchor'].to_i,
    hold_colors:   colors,
    grade_to_s:    row['grade'],
    openers:       openers,
    qr_svg:        qr_svg
  }
end

routes.sort_by! { |r| r[:anchor_number] }

pdf_io = DiscChartService.new(routes).generate_pdf

basename = File.basename(csv_path, File.extname(csv_path))
output_path = "/tmp/#{basename}.pdf"
File.binwrite(output_path, pdf_io.string)
puts "PDF written to #{output_path} (#{File.size(output_path)} bytes)"
puts "#{routes.size} routes across #{routes.map { |r| r[:anchor_number] }.uniq.size} anchors"
