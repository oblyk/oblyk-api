<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <style>
      body {
          font-family: sans-serif;
          font-size: 15px;
          color: #212121;
      }
      p, ul, li {
          color: #616161;
      }
      p {
          line-height: 1.5;
      }
    </style>
  </head>
  <body>
    <div
      style="
        height: 220px;
        margin-bottom: 30px;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
        background-image: url('<%= @app_url %>/images/oblyk-og-image.jpg');
        background-size: cover;
        border-radius: 10px;
      "
    ></div>
    <div
      style="
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
      "
    >
      <%= yield %>
      <p
        style="
          margin-top: 40px;
          text-align: right;
        "
      >
        <%= t('mailer.signature') %>
      </p>
      <p style="text-align: center; margin-top: 30px; margin-bottom: 0;">
        <small>🌱 <%= t('mailer.delete_this_email') %></small>
      </p>
      <p style="text-align: center; margin-top: 0;">
        <small>
          ⚙ <%= t('mailer.email_settings', url: "#{@app_url}/home/settings/notifications").html_safe %>
        </small>
      </p>
      <div>
        <div style="text-align: center">
          <p style="margin-bottom: 6px">
            <%= t('mailer.discovery_app') %>
          </p>
          <a style="margin-left: 4px; margin-right: 4px" href="https://play.google.com/store/apps/details?id=org.oblyk.twa"><img height="55" src="https://storage.oblyk.org/email-footer-google-play-btn-h110.png" alt="logo Google Play Store" ></a>
          <a style="margin-left: 4px; margin-right: 4px" href="https://apps.apple.com/fr/app/oblyk/id6569245391"><img height="55" src="https://storage.oblyk.org/email-footer-apple-store-btn-h110.png" alt="logo Apple App Store" ></a>
          <p style="margin-bottom: 6px">
            <%= t('mailer.follow_us') %>
          </p>
          <a style="color: black" href="https://www.facebook.com/pageoblyk">Facebook</a> ·
          <a style="color: black" href="https://www.instagram.com/oblyk.climbing">Instagram</a> ·
          <a style="color: black" href="https://github.com/oblyk">Github</a>
        </div>
      </div>
    </div>
  </body>
  <footer
    style="
      border-top-style: solid;
      border-top-color: #eeeeee;
      border-top-width: 1px;
      margin-top: 40px;
      padding-top: 20px;
      padding-bottom: 20px;
    "
  >
    <p
      style="
        color: #9e9e9e;
        font-size: 12px;
        font-weight: lighter;
        text-align: center;
      "
    >
      © <%= Date.current.year %> Oblyk. All rights reserved.
    </p>
  </footer>
</html>
